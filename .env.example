# ============================================
# Lega API - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----------------------------------------
# Required
# ----------------------------------------

# xAI Grok API key (obavezno za chat i toolove)
XAI_API_KEY=sk-...

# ----------------------------------------
# Important (strongly recommended in production)
# ----------------------------------------

# JWT Secret Key - generiraj jak random string!
# U developmentu možeš koristiti bilo što dugo.
# U produkciji OBAVEZNO promijeni!
JWT_SECRET_KEY=dev-only-super-secret-key-change-me-in-production-please-1234567890

# ----------------------------------------
# Optional
# ----------------------------------------

# Tavily API key - koristi se za fallback pretragu događaja
# Ako nije postavljen, Tavily fallback se preskače
TAVILY_API_KEY=

# ----------------------------------------
# Advanced / Future use
# ----------------------------------------

# DATABASE_URL=postgresql://user:pass@db:5432/lega   # kada migriramo na Postgres

# LOG_LEVEL=INFO
